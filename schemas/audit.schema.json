{
  "$defs": {
    "AuditItem": {
      "properties": {
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "warn",
            "fail"
          ],
          "title": "Status",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "status",
        "detail"
      ],
      "title": "AuditItem",
      "type": "object"
    },
    "PolicyContext": {
      "properties": {
        "allow_exec_command_count": {
          "default": 0,
          "minimum": 0,
          "title": "Allow Exec Command Count",
          "type": "integer"
        },
        "deny_capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Deny Capabilities",
          "type": "array"
        },
        "fail_on": {
          "anyOf": [
            {
              "enum": [
                "info",
                "low",
                "medium",
                "high",
                "critical"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fail On"
        },
        "policy_effect_count": {
          "default": 0,
          "minimum": 0,
          "title": "Policy Effect Count",
          "type": "integer"
        },
        "profile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Profile"
        },
        "require_approval_levels": {
          "items": {
            "enum": [
              "L0",
              "L1",
              "L2",
              "L3",
              "L4"
            ],
            "type": "string"
          },
          "title": "Require Approval Levels",
          "type": "array"
        },
        "waiver_count": {
          "default": 0,
          "minimum": 0,
          "title": "Waiver Count",
          "type": "integer"
        }
      },
      "title": "PolicyContext",
      "type": "object"
    },
    "PolicyDecision": {
      "properties": {
        "action": {
          "enum": [
            "allow",
            "allow_with_constraints",
            "require_approval",
            "deny",
            "quarantine"
          ],
          "title": "Action",
          "type": "string"
        },
        "network": {
          "default": "allow",
          "enum": [
            "allow",
            "restricted",
            "deny"
          ],
          "title": "Network",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "require_approval": {
          "default": false,
          "title": "Require Approval",
          "type": "boolean"
        },
        "sandbox": {
          "default": false,
          "title": "Sandbox",
          "type": "boolean"
        }
      },
      "required": [
        "action"
      ],
      "title": "PolicyDecision",
      "type": "object"
    },
    "PolicyEffect": {
      "properties": {
        "action": {
          "enum": [
            "ignored",
            "downgraded",
            "expired"
          ],
          "title": "Action",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "policy_ref": {
          "title": "Policy Ref",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "action",
        "finding_id",
        "location",
        "reason",
        "policy_ref"
      ],
      "title": "PolicyEffect",
      "type": "object"
    },
    "RiskFactor": {
      "properties": {
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "occurrences": {
          "default": 1,
          "minimum": 1,
          "title": "Occurrences",
          "type": "integer"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Score",
          "type": "integer"
        },
        "source_finding_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Finding Ids",
          "type": "array"
        }
      },
      "required": [
        "id",
        "score",
        "reason"
      ],
      "title": "RiskFactor",
      "type": "object"
    },
    "RuleExplanation": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "owasp": {
          "items": {
            "type": "string"
          },
          "title": "Owasp",
          "type": "array"
        },
        "policy_action": {
          "enum": [
            "allow",
            "allow_with_constraints",
            "require_approval",
            "deny",
            "quarantine"
          ],
          "title": "Policy Action",
          "type": "string"
        },
        "recommendation": {
          "title": "Recommendation",
          "type": "string"
        },
        "risk_level": {
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3",
            "L4"
          ],
          "title": "Risk Level",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "severity",
        "category",
        "capability",
        "risk_level",
        "policy_action",
        "description",
        "recommendation"
      ],
      "title": "RuleExplanation",
      "type": "object"
    },
    "RuntimePolicyReport": {
      "properties": {
        "default_action": {
          "enum": [
            "allow",
            "allow_with_constraints",
            "require_approval",
            "deny",
            "quarantine"
          ],
          "title": "Default Action",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/RuntimePolicyRule"
          },
          "title": "Rules",
          "type": "array"
        },
        "schema_version": {
          "const": "mcp-admit.runtime-policy.v1",
          "default": "mcp-admit.runtime-policy.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "source_schema_version": {
          "title": "Source Schema Version",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "tool_version": {
          "default": "0.3.0",
          "title": "Tool Version",
          "type": "string"
        }
      },
      "required": [
        "target",
        "source_schema_version",
        "default_action",
        "rules"
      ],
      "title": "RuntimePolicyReport",
      "type": "object"
    },
    "RuntimePolicyRule": {
      "properties": {
        "action": {
          "enum": [
            "allow",
            "allow_with_constraints",
            "require_approval",
            "deny",
            "quarantine"
          ],
          "title": "Action",
          "type": "string"
        },
        "finding_ids": {
          "items": {
            "type": "string"
          },
          "title": "Finding Ids",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "match": {
          "additionalProperties": true,
          "title": "Match",
          "type": "object"
        },
        "network": {
          "enum": [
            "allow",
            "restricted",
            "deny"
          ],
          "title": "Network",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "require_approval": {
          "title": "Require Approval",
          "type": "boolean"
        },
        "risk_level": {
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3",
            "L4"
          ],
          "title": "Risk Level",
          "type": "string"
        },
        "risk_score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Risk Score",
          "type": "integer"
        },
        "sandbox": {
          "title": "Sandbox",
          "type": "boolean"
        },
        "scope": {
          "enum": [
            "default",
            "capability",
            "finding"
          ],
          "title": "Scope",
          "type": "string"
        }
      },
      "required": [
        "id",
        "scope",
        "action",
        "require_approval",
        "sandbox",
        "network",
        "risk_level",
        "risk_score",
        "reason"
      ],
      "title": "RuntimePolicyRule",
      "type": "object"
    },
    "ScanSummary": {
      "properties": {
        "approval_required": {
          "title": "Approval Required",
          "type": "boolean"
        },
        "credential_review_required": {
          "title": "Credential Review Required",
          "type": "boolean"
        },
        "egress_review_required": {
          "title": "Egress Review Required",
          "type": "boolean"
        },
        "gate_result": {
          "enum": [
            "pass",
            "warn",
            "fail"
          ],
          "title": "Gate Result",
          "type": "string"
        },
        "max_severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Max Severity",
          "type": "string"
        },
        "recommended_policy": {
          "$ref": "#/$defs/PolicyDecision"
        },
        "risk_factors": {
          "items": {
            "$ref": "#/$defs/RiskFactor"
          },
          "title": "Risk Factors",
          "type": "array"
        },
        "risk_score": {
          "title": "Risk Score",
          "type": "integer"
        },
        "risk_score_method": {
          "const": "max_finding_with_composition",
          "default": "max_finding_with_composition",
          "title": "Risk Score Method",
          "type": "string"
        },
        "sandbox_required": {
          "title": "Sandbox Required",
          "type": "boolean"
        },
        "tool_risk_level": {
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3",
            "L4"
          ],
          "title": "Tool Risk Level",
          "type": "string"
        },
        "total_findings": {
          "title": "Total Findings",
          "type": "integer"
        }
      },
      "required": [
        "total_findings",
        "max_severity",
        "risk_score",
        "tool_risk_level",
        "gate_result",
        "approval_required",
        "sandbox_required",
        "egress_review_required",
        "credential_review_required",
        "recommended_policy"
      ],
      "title": "ScanSummary",
      "type": "object"
    }
  },
  "$id": "https://github.com/aolune/mcp-admit/schemas/audit.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "gate_result": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ],
      "title": "Gate Result",
      "type": "string"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/AuditItem"
      },
      "title": "Items",
      "type": "array"
    },
    "next_actions": {
      "items": {
        "type": "string"
      },
      "title": "Next Actions",
      "type": "array"
    },
    "policy_context": {
      "$ref": "#/$defs/PolicyContext"
    },
    "policy_effects": {
      "items": {
        "$ref": "#/$defs/PolicyEffect"
      },
      "title": "Policy Effects",
      "type": "array"
    },
    "rule_explanations": {
      "items": {
        "$ref": "#/$defs/RuleExplanation"
      },
      "title": "Rule Explanations",
      "type": "array"
    },
    "runtime_policy": {
      "$ref": "#/$defs/RuntimePolicyReport"
    },
    "scan_summary": {
      "$ref": "#/$defs/ScanSummary"
    },
    "schema_version": {
      "const": "mcp-admit.audit.v1",
      "default": "mcp-admit.audit.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "target": {
      "title": "Target",
      "type": "string"
    },
    "tool_version": {
      "default": "0.3.0",
      "title": "Tool Version",
      "type": "string"
    }
  },
  "required": [
    "target",
    "gate_result",
    "runtime_policy",
    "scan_summary",
    "items"
  ],
  "title": "MCP Admit Audit Report",
  "type": "object"
}